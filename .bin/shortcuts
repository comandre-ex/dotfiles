#!/bin/bash
# shortcuts - Muestra atajos de teclado
# Uso: shortcuts [seccion]

CAT='\033[0;34m'
CYA='\033[0;36m'
GRE='\033[0;32m'
YEL='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_section() {
    local title="$1"
    local file="$HOME/shortcuts.md"
    if [[ -f "$file" ]]; then
        echo -e "${CAT}═══════════════════════════════════════════════${NC}"
        echo -e "${CAT}  $title${NC}"
        echo -e "${CAT}═══════════════════════════════════════════════${NC}"
        echo ""
    fi
}

case "$1" in
    bspwm|wm)
        show_section "BSPWM / SXHKD"
        if [[ -f "$HOME/.config/sxhkd/sxhkdrc" ]]; then
            grep -E "^\s*(super|ctrl|alt)" "$HOME/.config/sxhkd/sxhkdrc" | grep -v "^#" | head -40
        else
            echo -e "${CYA}Aplicaciones:${NC}"
            echo "  Super + Enter    → Kitty"
            echo "  Super + r        → Rofi"
            echo "  Super + Shift + e → Thunar"
            echo ""
            echo -e "${CYA}Navegación:${NC}"
            echo "  Super + h/j/k/l  → Mover foco (vim)"
            echo "  Super + c        → Cerrar ventana"
            echo "  Super + w        → Forzar cierre"
            echo ""
            echo -e "${CYA}Escritorios:${NC}"
            echo "  Super + 1-9      → Cambiar escritorio"
        fi
        ;;
    sxhkd)
        show_section "SXHKD"
        echo -e "${CYA}Aplicaciones:${NC}"
        echo "  super + return     → Kitty"
        echo "  super + r          → Rofi"
        echo "  super + shift + e  → Thunar"
        echo "  super + shift + f  → Firefox"
        echo "  super + shift + c  → Caido"
        echo "  super + shift + o  → Obsidian"
        echo ""
        echo -e "${CYA}Gestión BSPWM:${NC}"
        echo "  super + alt + q    → Salir"
        echo "  super + alt + r    → Reiniciar"
        echo "  super + escape     → Recargar sxhkd"
        echo "  super + c          → Cerrar ventana"
        echo "  super + w          → Forzar cierre"
        echo ""
        echo -e "${CYA}Movimiento:${NC}"
        echo "  super + h/j/k/l    → Mover foco (vim)"
        echo "  super + shift + h/j/k/l → Intercambiar"
        echo "  super + ctrl + h/j/k/l → Preseleccionar"
        echo ""
        echo -e "${CYA}Redimensionado:${NC}"
        echo "  super + alt + h/j/k/l → Expandir"
        echo "  super + alt + shift + h/j/k/l → Contraer"
        echo ""
        echo -e "${CYA}Escritorios:${NC}"
        echo "  super + 1-9,0     → Cambiar escritorio"
        echo "  super + shift + 1-9,0 → Enviar ventana"
        echo ""
        echo -e "${CYA}Estados:${NC}"
        echo "  super + f          → Fullscreen"
        echo "  super + s           → Flotante"
        echo "  super + z           → Captura (Flameshot)"
        ;;
    kitty|term)
        show_section "KITTY"
        echo -e "${CYA}General (Ctrl+Shift):${NC}"
        echo "  Ctrl+Shift+r     → Recargar config"
        echo "  Ctrl+Shift+z     → Fullscreen"
        echo "  Ctrl+Shift+Enter → Nueva ventana"
        echo "  Ctrl+Shift+t     → Nueva pestaña"
        echo "  Ctrl+Shift+w     → Cerrar pestaña"
        echo "  Ctrl+w           → Cerrar ventana"
        echo "  Ctrl+Shift+c     → Copiar"
        echo "  Ctrl+Shift+v     → Pegar"
        echo ""
        echo -e "${CYA}Navegación (Ctrl):${NC}"
        echo "  Ctrl+←/→/↑/↓    → Mover a ventana"
        echo "  Ctrl+Shift+,     → Pestaña anterior"
        echo "  Ctrl+Shift+.     → Próxima pestaña"
        echo "  Ctrl+Alt+1-5     → Ir a pestaña"
        echo ""
        echo -e "${CYA}Paneles/Layout:${NC}"
        echo "  Ctrl+Alt+h       → Split horizontal"
        echo "  Ctrl+Alt+v       → Split vertical"
        echo "  Ctrl+Shift+l     → Siguiente layout"
        echo "  Ctrl+Alt+z       → Toggle stack"
        echo ""
        echo -e "${CYA}Redimensionado (Ctrl+Shift+arrows):${NC}"
        echo "  ↑    → Ampliar altura"
        echo "  ↓    → Reducir altura"
        echo "  ←    → Ampliar ancho"
        echo "  →    → Reducir ancho"
        echo ""
        echo -e "${CYA}Editor:${NC}"
        echo "  Ctrl+Shift+e     → Abrir nvim"
        echo ""
        echo -e "${CYA}Scroll (Ctrl+Shift):${NC}"
        echo "  k     → Línea arriba"
        echo "  j     → Línea abajo"
        echo "  PageUp/PageDown → Página"
        echo "  Home/End → Inicio/Fin"
        echo ""
        echo -e "${CYA}Búsqueda:${NC}"
        echo "  Ctrl+Shift+/  o Ctrl+Shift+f → Buscar"
        echo ""
        echo -e "${CYA}Navegación (Ctrl):${NC}"
        echo "  Ctrl+←/→/↑/↓    → Mover a ventana"
        echo "  Alt+Shift+Tab    → Próxima pestaña"
        echo "  Alt+Shift+p      → Pestaña anterior"
        echo ""
        echo -e "${CYA}Paneles/Layout:${NC}"
        echo "  Alt+Shift+h      → Split horizontal"
        echo "  Ctrl+Alt+v       → Split vertical"
        echo ""
        echo -e "${CYA}Redimensionado:${NC}"
        echo "  Alt+Shift+↑    → Ampliar altura"
        echo "  Alt+Shift+↓    → Reducir altura"
        echo "  Alt+Shift+←    → Ampliar ancho"
        echo "  Alt+Shift+→    → Reducir ancho"
        echo ""
        echo -e "${CYA}Editor:${NC}"
        echo "  Alt+Shift+e     → Abrir nvim"
        echo ""
        echo -e "${CYA}Scroll:${NC}"
        echo "  Alt+Shift+k     → Línea arriba"
        echo "  Alt+Shift+j     → Línea abajo"
        echo "  Alt+Shift+f     → Página abajo"
        echo "  Alt+Shift+PageUp/Down → Página"
        ;;
    shell|zsh)
        show_section "ZSH"
        echo -e "${CYA}Navegación:${NC}"
        echo "  Ctrl+a/e         → Inicio/Fin línea"
        echo "  Ctrl+w           → Borrar palabra"
        echo "  ↑/↓              → Historial"
        echo "  Ctrl+r           → Buscar historial"
        echo ""
        echo -e "${CYA}Comandos:${NC}"
        echo "  extractPorts     → Extraer puertos nmap"
        echo "  mkt              → Crear dirs nmap"
        echo "  cdp              → Directorio proyecto"
        ;;
    git)
        show_section "GIT"
        echo -e "${GRE} alias gs   → git status"
        echo " alias ga   → git add"
        echo " alias gc   → git commit"
        echo " alias gp   → git push"
        echo " alias gl   → git log"
        echo " alias gco  → git checkout"
        echo " alias gb   → git branch"
        ;;
    docker)
        show_section "DOCKER"
        echo -e "${CYA} alias d    → docker"
        echo " alias dc   → docker compose"
        echo " alias dps  → lista contenedores"
        echo " alias di   → lista imágenes"
        ;;
    k8s|kube)
        show_section "KUBERNETES"
        echo -e "${RED} alias k    → kubectl"
        echo " alias kgp  → get pods"
        echo " alias kgs  → get services"
        echo " alias kgd  → get deployments"
        ;;
    all|*)
        echo -e "${CAT}╔════════════════════════════════════════╗${NC}"
        echo -e "${CAT}║      COMANDRE'S SHORTCUTS v2026       ║${NC}"
        echo -e "${CAT}╚════════════════════════════════════════╝${NC}"
        echo ""
        echo "Usage: shortcuts [seccion]"
        echo ""
        echo -e "${YEL}Secciones disponibles:${NC}"
        echo "  bspwm   - Window manager"
        echo "  sxhkd   - Atajos SXHKD (detalle)"
        echo "  kitty   - Terminal"
        echo "  shell   - ZSH/FZF"
        echo "  git     - Aliases Git"
        echo "  docker  - Docker"
        echo "  k8s     - Kubernetes"
        echo "  all     - Mostrar todo"
        echo ""
        echo " También consulta: ~/shortcuts.md"
        ;;
esac