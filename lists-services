#!/usr/bin/env bash

RED=$'\033[31m'
GREEN=$'\033[32m'
MAGENTA=$'\033[35m'
RESET=$'\033[0m'

awk -v R="$RED" -v G="$GREEN" -v M="$MAGENTA" -v S="$RESET" '
# Función manual para convertir Hex a Decimal
function hex2dec(h,   i, x, d) {
    h = tolower(h);
    d = 0;
    for (i=1; i<=length(h); i++) {
        x = index("0123456789abcdef", substr(h, i, 1)) - 1;
        d = d * 16 + x;
    }
    return d;
}

NR==FNR {if(!/^#/ && NF){split($2,a,"/"); if(a[2]=="tcp" || a[2]=="udp") services[a[1]]=$1} next} 
FNR>1 {
    split($2,a,":"); 
    # Usamos nuestra función en lugar de strtonum
    port=hex2dec(a[2]); 
    svc=services[port]; 
    if(!svc) next; 
    proto=(FILENAME~/tcp$/?"TCP":"UDP"); 
    printf M"%s:%d"S" -> "G"%s"S"\n", proto, port, svc
}' /etc/services /proc/net/tcp /proc/net/udp | sort -t: -k2 -n | uniq
